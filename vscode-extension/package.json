{
  "name": "pr-pilot-vscode",
  "displayName": "PR Pilot",
  "description": "AI-powered pull request reviews",
  "version": "0.1.0",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [{ "id": "pr-pilot", "title": "PR Pilot", "icon": "$(git-pull-request)" }]
    },
    "views": {
      "pr-pilot": [{ "id": "pr-pilot.main", "name": "PR Pilot", "type": "webview" }]
    },
    "configuration": {
      "title": "PR Pilot",
      "properties": {
        "pr-pilot.githubBaseUrl": {
          "type": "string",
          "default": "https://github.com",
          "description": "GitHub base URL. Change for GitHub Enterprise (e.g. https://github.mycompany.com)."
        },
        "pr-pilot.reviewModel": {
          "type": "string",
          "default": "",
          "description": "Model ID to use for reviews. Empty uses the CLI default."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json"
  },
  "dependencies": {
    "core": "file:../core/build/js/packages/core"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
