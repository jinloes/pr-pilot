<idea-plugin>
    <id>com.jinloes.prpilot</id>
    <name>PR Pilot</name>
    <vendor>PR Pilot</vendor>
    <description><![CDATA[
        Browse GitHub Pull Requests assigned to you or any accessible repository
        and generate AI-powered code reviews using your local Claude CLI session.
        Preview and edit the review before sharing.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="PR Pilot"
                    secondary="false"
                    anchor="right"
                    factoryClass="com.jinloes.prpilot.ui.PRToolWindowFactory"/>

        <applicationService
            serviceImplementation="com.jinloes.prpilot.settings.PluginSettings"/>

        <applicationService
            serviceImplementation="com.jinloes.prpilot.services.GitHubService"/>

        <applicationService
            serviceImplementation="com.jinloes.prpilot.services.PRNotificationService"/>

        <applicationConfigurable
            parentId="tools"
            instance="com.jinloes.prpilot.settings.PluginSettingsConfigurable"
            id="com.jinloes.prpilot.settings.PluginSettingsConfigurable"
            displayName="PR Pilot"/>

        <notificationGroup id="PR Pilot"
                           displayType="BALLOON"
                           isLogByDefault="true"/>

        <postStartupActivity
            implementation="com.jinloes.prpilot.services.PRNotificationStartup"/>
    </extensions>
</idea-plugin>